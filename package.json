{
  "name": "media-swap",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "package:install": "pnpm install",
    "dev": "next dev | pino-pretty -tc",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "pnpm prettier .",
    "format:fix": "pnpm prettier . --write",
    "db:dev": "docker-compose up -d",
    "db:seed": "prisma db seed",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:show": "prisma studio",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "depcheck": "pnpx depcheck",
    "prepare": "husky install",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "init": "docker compose build --no-cache && docker compose up -d && pnpm i && pnpm run db:generate && pnpm run db:push && pnpm run dev",
    "initdev": "pnpm i && pnpm run db:generate && pnpm run db:push && pnpm run dev",
    "initdb": "docker compose build --no-cache && docker compose up -d",
    "startdb": "docker compose start",
    "enddb": "docker compose down"
  },
  "husky": {
    "hooks": {
      "pre-push": "pnpm prettier . --write && pnpm run lint"
    }
  },
  "dependencies": {
    "@auth/prisma-adapter": "^1.0.9",
    "@prisma/client": "^5.6.0",
    "@vercel/edge-config": "^1.1.0",
    "autoprefixer": "10.4.18",
    "daisyui": "^4.7.2",
    "date-fns": "^3.3.1",
    "heic2any": "^0.0.4",
    "jotai": "^2.6.5",
    "next": "14.2.3",
    "next-auth": "4.24.6",
    "next-client-cookies": "^1.1.0",
    "next-compose-middleware": "^1.0.0",
    "nodemailer": "^6.9.10",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "postcss": "8.4.35",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-dropzone": "^14.2.3",
    "react-google-recaptcha-v3": "^1.10.1",
    "react-hot-toast": "^2.4.1",
    "react-icons": "5.0.1",
    "react-remove-scroll": "^2.5.7",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "3.4.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^10.8.0",
    "@playwright/test": "^1.41.2",
    "@quramy/prisma-fabbrica": "^2.1.0",
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/addon-interactions": "^8.0.0",
    "@storybook/addon-links": "^8.0.0",
    "@storybook/addon-onboarding": "^8.0.0",
    "@storybook/blocks": "^8.0.0",
    "@storybook/nextjs": "^8.0.0",
    "@storybook/react": "^8.0.0",
    "@storybook/test": "^8.0.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.20",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^18.2.60",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.1.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-functional": "^6.0.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-jest-dom": "^5.1.0",
    "eslint-plugin-jsdoc": "^48.2.0",
    "eslint-plugin-local-rules": "^2.0.1",
    "eslint-plugin-playwright": "^1.5.1",
    "eslint-plugin-prefer-arrow-functions": "^3.3.1",
    "eslint-plugin-storybook": "^0.8.0",
    "eslint-plugin-tailwindcss": "^3.14.3",
    "eslint-plugin-testing-library": "^6.2.0",
    "eslint-plugin-unicorn": "^51.0.1",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-mock-extended": "^3.0.5",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "prisma": "^5.6.0",
    "prisma-erd-generator": "^1.11.2",
    "storybook": "^8.0.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "schema": "db/schema.prisma",
    "seed": "node db/seed.js"
  },
  "engines": {
    "npm": "🔥パッケージマネージャーはnpmではなくpnpmを使用してください。 see https://pnpm.io/installation",
    "yarn": "🔥パッケージマネージャーはyarnではなくpnpmを使用してください。see https://pnpm.io/installation"
  },
  "packageManager": "pnpm@8.15.4"
}
